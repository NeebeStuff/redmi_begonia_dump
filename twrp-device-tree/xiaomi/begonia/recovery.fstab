/system_root     ext4     /dev/block/platform/bootdevice/by-name/system       flags=display=system_root
/vendor          ext4     /dev/block/platform/bootdevice/by-name/vendor       flags=display=vendor
/data            ext4     /dev/block/platform/bootdevice/by-name/userdata     flags=display=data
/data            f2fs     /dev/block/platform/bootdevice/by-name/userdata     flags=display=data
/misc            emmc     /dev/block/platform/bootdevice/by-name/misc         flags=display=misc
